Depends:
    R (>= 4.1.0)
Imports:
    graphics,
    methods,
    Rcpp,
    stats
LinkingTo:
    Rcpp,
    RcppArmadillo,
    RcppEigen
Suggests:
    knitr,
    rmarkdown
SystemRequirements: C++17
VignetteBuilder: knitr
